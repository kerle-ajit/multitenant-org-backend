{
  "name": "multi-tenant-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "ts-node-dev src/modules/email/email.worker.ts",
    "worker:start": "node dist/modules/email/email.worker.js",
    "seed": "ts-node prisma/seed.ts",
    "seed:docker": "docker compose exec app npm run seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
